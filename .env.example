# Database (Neon / Supabase PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/hipaaa?schema=public

# VanillaSoft Incoming Web Lead POST URLs
VS_REFERRAL_POST_URL=https://s2.vanillasoft.net/web/post.aspx?id=1007863
VS_INTAKE_POST_URL=https://s2.vanillasoft.net/web/post.aspx?id=1007862
VS_ENROLLMENT_POST_URL=https://s2.vanillasoft.net/web/post.aspx?id=1007864

# JotForm
JOTFORM_API_KEY=
# If set, webhooks must send the same value as header x-jotform-webhook-secret or query webhook_secret
JOTFORM_WEBHOOK_SECRET=

# SharePoint (Microsoft Graph API)
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=
SHAREPOINT_TENANT_ID=
SHAREPOINT_SITE_ID=
SHAREPOINT_DRIVE_ID=

# Admin (required for admin-review and admin-replay; omit only if those functions are disabled)
ADMIN_API_KEY=
